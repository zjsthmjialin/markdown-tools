{
  "name": "markany",
  "version": "1.0.0",
  "description": "文档双向转换工具",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "python:build": "cd src/python && pyinstaller markany-backend.spec --clean --noconfirm",
    "build": "npm run python:build && tsc && vite build && electron-builder --win",
    "build:dir": "npm run python:build && tsc && vite build && electron-builder --win --dir",
    "build:no-python": "tsc && vite build && electron-builder --win --dir",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:python": "cd src/python && python -m pytest tests/ -v",
    "test:all": "npm run test && npm run test:python"
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^29.4.0",
    "electron-builder": "^24.9.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^4.1.6"
  }
}
